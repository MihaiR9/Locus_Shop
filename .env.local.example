# Copy to .env.local and fill with real values from your Supabase project.
# .env.local is gitignored — never commit real keys.

# ─── Supabase ──────────────────────────────────────────────────
# Project Settings → API
# https://supabase.com/dashboard/project/<your-project>/settings/api

# Public — safe to expose in browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only — bypasses RLS. Used by webhooks / cron / admin server actions.
# NEVER expose this to the browser. NEVER commit it.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Stripe (Pas 5) ────────────────────────────────────────────
# Dashboard → Developers → API keys
# Test mode keys (sk_test_..., pk_test_...) work end-to-end with Stripe's
# test cards. Live keys (sk_live_...) require KYC + activated account.

# Server-only — used by the createOrder server action + webhook handler.
STRIPE_SECRET_KEY=sk_test_...

# Browser-safe — only needed if you ever switch from hosted Checkout to
# Stripe Elements. Leave commented for now.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook signing secret — Dashboard → Developers → Webhooks → "your endpoint"
# → Signing secret. The endpoint POSTS to /api/stripe/webhook on this domain.
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL — used to build Stripe success/cancel redirect URLs.
# In production this becomes the canonical domain. For local dev with
# Stripe CLI forwarding, leave http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (Faza 2) ───────────────────────────────────────────
# RESEND_API_KEY=re_...

# ─── Resend (Pas 6) ────────────────────────────────────────────
# Dashboard → API Keys → Create → Full access. Begins with re_…
RESEND_API_KEY=re_...

# Cine apare ca expeditor. Until you verify a domain in Resend (DNS
# SPF + DKIM records), you can only use "onboarding@resend.dev" as
# the sender. Once verified, switch to office@domeniul-locus.ro.
RESEND_FROM_EMAIL=Domeniul Locus <onboarding@resend.dev>

# DEV mode: Resend sandbox doesn't let you send to arbitrary recipients
# until your domain is verified. Set this to your own Resend account
# email and ALL outbound messages get redirected here. Remove (set to
# empty) in production.
RESEND_DEV_REDIRECT=youremail@example.com

# Internal admin notifications go here (new orders, contact form).
RESEND_ADMIN_EMAIL=office@domeniul-locus.ro

# ─── Analytics (when consent banner has IDs to load) ───────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=000000000000000
